# Copy this to .env.local and fill in your values.
# NEVER commit .env.local

NODE_ENV=development

# Supabase
# Local dev default: run `supabase start` and copy the printed values here.
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Auth
NEXTAUTH_SECRET=any_random_string_in_dev
NEXTAUTH_URL=http://localhost:3000
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Payments (TEST keys — safe, no real money)
# RAZORPAY_KEY_ID and NEXT_PUBLIC_RAZORPAY_KEY_ID must be the SAME value
# Public key goes to the browser (Razorpay modal); secret key stays server-only
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXX
RAZORPAY_KEY_SECRET=your_test_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Email
RESEND_API_KEY=re_XXXXXXXXXX

# Cloudflare R2 — media storage
# CF_ACCOUNT_ID: Cloudflare account ID (found in Workers & Pages dashboard)
# R2_ACCESS_KEY_ID + R2_SECRET_ACCESS_KEY: R2 API token with Object Read & Write
# R2_BUCKET_NAME: e.g. possah-media
# NEXT_PUBLIC_R2_PUBLIC_URL: public base URL for the bucket, e.g. https://pub-xxxxxxxx.r2.dev
#   (or your custom domain if you've added one in R2 → Settings → Custom domains)
CF_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=possah-media
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# Analytics (can be empty in dev — will not crash)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Admin email — receives order notifications
ADMIN_EMAIL=thedenn0007@gmail.com

# Sentry — error monitoring
# Run: npm install @sentry/nextjs
# Then set these in Vercel dashboard as secrets (not in .env.local)
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxx@xxxxxxxx.ingest.sentry.io/xxxxxxxx
SENTRY_ORG=your_sentry_org_slug
SENTRY_PROJECT=the-possah
# SENTRY_AUTH_TOKEN — generate at https://sentry.io/settings/account/api/auth-tokens/
# needs project:releases + org:read + project:write scopes
SENTRY_AUTH_TOKEN=sntrys_xxxxxxxxxxxx
